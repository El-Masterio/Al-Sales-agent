# =============================================================================
# AI Sales Agent — Environment Variables
# Copy to .env and fill in values. Never commit .env to version control.
# =============================================================================

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development                         # development | staging | production
APP_NAME="AI Sales Agent"
APP_VERSION=1.0.0
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true
APP_LOG_LEVEL=INFO                          # DEBUG | INFO | WARNING | ERROR
SECRET_KEY=your-secret-key-min-32-chars-change-this-now
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/sales_agent
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=3600
DATABASE_ECHO=false                         # true logs all SQL (dev only)

# Sync URL for Alembic migrations (uses psycopg2)
DATABASE_SYNC_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/sales_agent

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_CELERY_BROKER=redis://localhost:6379/1
REDIS_CELERY_BACKEND=redis://localhost:6379/2
REDIS_CACHE_DB=3
REDIS_MAX_CONNECTIONS=50
REDIS_SOCKET_TIMEOUT=5
REDIS_SOCKET_CONNECT_TIMEOUT=5

# ── JWT Auth ──────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=your-jwt-secret-key-change-this-now
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_ORG_ID=org-...                       # optional
OPENAI_DEFAULT_MODEL=gpt-4.1
OPENAI_FAST_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_MAX_RETRIES=3
OPENAI_TIMEOUT=60
OPENAI_MAX_TOKENS=4096

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=4096

# ── Google Gemini ─────────────────────────────────────────────────────────────
GOOGLE_AI_API_KEY=AIza...
GEMINI_DEFAULT_MODEL=gemini-1.5-pro

# ── LLM Router ────────────────────────────────────────────────────────────────
LLM_PRIMARY_PROVIDER=openai                 # openai | anthropic | google
LLM_FALLBACK_PROVIDER=anthropic
LLM_TEMPERATURE=0.7
LLM_RESEARCH_TEMPERATURE=0.2               # lower = more factual for research tasks
LLM_CREATIVE_TEMPERATURE=0.9               # higher for personalized email copy

# ── Email — SendGrid ──────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG....
SENDGRID_WEBHOOK_KEY=your-sendgrid-webhook-signing-secret
SENDGRID_TRACKING_DOMAIN=track.yourdomain.com

# ── Email — AWS SES ───────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1
SES_CONFIGURATION_SET=sales-agent-tracking
SES_FROM_EMAIL=noreply@yourdomain.com

# ── Email — SMTP fallback ─────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=you@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# ── Email Tracking ────────────────────────────────────────────────────────────
EMAIL_TRACKING_BASE_URL=https://track.yourdomain.com
EMAIL_OPEN_PIXEL_PATH=/t/{tracking_id}/open.png
EMAIL_CLICK_REDIRECT_PATH=/t/{tracking_id}/click

# ── Google Calendar ───────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-oauth2-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/calendar/oauth/callback
GOOGLE_SCOPES=https://www.googleapis.com/auth/calendar

# ── Lead Enrichment ───────────────────────────────────────────────────────────
# Hunter.io — email finding
HUNTER_API_KEY=your-hunter-api-key

# Clearbit — company/contact enrichment
CLEARBIT_API_KEY=sk_...

# Crunchbase — funding/company data
CRUNCHBASE_API_KEY=your-crunchbase-key

# Apollo.io — contact database (alternative to Hunter)
APOLLO_API_KEY=your-apollo-key

# ── Web Scraping ──────────────────────────────────────────────────────────────
SCRAPER_PROXY_URL=http://user:pass@proxy.provider.com:8080
SCRAPER_TIMEOUT=30
SCRAPER_MAX_RETRIES=3
SCRAPER_RATE_LIMIT_RPS=2                   # requests per second per domain
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_SLOW_MO=0

# ── Celery ────────────────────────────────────────────────────────────────────
CELERY_WORKER_CONCURRENCY=4
CELERY_TASK_SOFT_TIME_LIMIT=300            # 5 min soft limit
CELERY_TASK_TIME_LIMIT=600                 # 10 min hard limit
CELERY_MAX_RETRIES=3
CELERY_RETRY_BACKOFF=60                    # seconds between retries

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=100/minute              # global default
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_EMAIL_SEND=50/hour             # per campaign
EMAIL_DAILY_SEND_LIMIT=500                 # absolute daily cap
EMAIL_HOURLY_SEND_LIMIT=50

# ── Campaign Defaults ─────────────────────────────────────────────────────────
DEFAULT_FOLLOW_UP_DAYS=3,7,14
DEFAULT_MAX_ATTEMPTS=4
DEFAULT_EMAIL_PROVIDER=sendgrid
DEFAULT_LLM_MODEL=gpt-4.1

# ── Observability ─────────────────────────────────────────────────────────────
SENTRY_DSN=https://...@sentry.io/...
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1
SENTRY_ENVIRONMENT=development

PROMETHEUS_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# ── Security ──────────────────────────────────────────────────────────────────
ENCRYPTION_KEY=your-32-byte-fernet-key-base64-encoded==
WEBHOOK_SECRET=your-webhook-signing-secret
CORS_ALLOW_CREDENTIALS=true
TRUSTED_HOSTS=localhost,yourdomain.com
API_KEY_HEADER=X-API-Key

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# ── Feature Flags ─────────────────────────────────────────────────────────────
FEATURE_AUTO_RESEARCH=true
FEATURE_AUTO_OUTREACH=true
FEATURE_AUTO_FOLLOWUP=true
FEATURE_REPLY_CLASSIFICATION=true
FEATURE_AUTO_BOOKING=true
FEATURE_AI_MEMORY=true
FEATURE_LINKEDIN_SCRAPING=true             # requires proxy
